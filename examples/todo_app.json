{
  "intent": {
    "raw_text": "Build a simple todo app where users can create, complete, and delete their own tasks.",
    "entities": [
      {"name": "Task", "attributes": ["title", "completed", "due_date"]}
    ],
    "roles": [
      {"name": "user"}
    ],
    "features": ["auth", "crud"],
    "ambiguities": [
      {
        "field": "due_date",
        "message": "Should due_date be mandatory or optional?"
      }
    ]
  },
  "architecture": {
    "entities": [
      {
        "name": "Task",
        "attributes": ["id", "title", "completed", "due_date", "created_at", "owner_id"]
      }
    ],
    "relations": [],
    "roles": [
      {"name": "user", "description": "Owns and manages their own tasks."}
    ],
    "flows": [
      {
        "name": "createTask",
        "actor": "user",
        "steps": [
          "Navigate to /tasks",
          "Fill in title and optional due date",
          "Submit → POST /tasks"
        ]
      },
      {
        "name": "completeTask",
        "actor": "user",
        "steps": [
          "View task list → GET /tasks",
          "Click checkbox → PATCH /tasks/{id}"
        ]
      },
      {
        "name": "deleteTask",
        "actor": "user",
        "steps": [
          "Click delete button → DELETE /tasks/{id}"
        ]
      }
    ],
    "assumptions": []
  },
